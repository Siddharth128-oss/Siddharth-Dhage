DROP Table students;
CREATE TABLE students (
    student_id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    age INTEGER,
    address TEXT,
    math INTEGER,
    science INTEGER,
    english INTEGER,
    hindi INTEGER,
    total INTEGER,
    average INTEGER,
    percentage INTEGER
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

